#!/bin/zsh
# Internal launcher for all Java-backed chordprotools commands.
#
# Runs the packaged fat JAR directly (java -jar) instead of going through
# `mvn spring-boot:run`, which avoids Maven's startup overhead on every call
# (~5-10s → <1s).
#
# Behaviour ("never go stale"):
#   - JAR missing            → build it automatically, then run
#   - JAR out of date        → rebuild it automatically, then run
#   - everything up to date  → run immediately (fast path)
#
# "Out of date" = any file under src/main, or pom.xml, is newer than the JAR.
# This means a plain `git pull` that changes code, resources, or dependencies
# is picked up automatically — you never have to remember to run ./build.
#
# You normally never call this directly — the command shims (export-setlist,
# deploy-rc500, etc.) delegate to it. But you can:
#   ./cpt deploy-rc500 --gig 2026-06-14-rusty-nail
#   ./cpt --help

set -euo pipefail
DIR="${0:a:h}"

jar_path() {
ls "$DIR"/target/chordpro-tools-*.jar 2>/dev/null | grep -v '\.original$' | head -1
}

# Is a rebuild needed? True if no JAR, or any source/pom is newer than the JAR.
needs_build() {
  local jar="$1"
  [[ -z "$jar" ]] && return 0
  [[ -n "$(find "$DIR/src/main" "$DIR/pom.xml" -newer "$jar" -type f -print -quit 2>/dev/null)" ]]
}

JAR=$(jar_path)

if needs_build "$JAR"; then
  if [[ -z "$JAR" ]]; then
    echo "⚙  No JAR found — building first (one-time)..." >&2
  else
    echo "⚙  Sources changed since last build — rebuilding..." >&2
  fi
  "$DIR/build" >&2
  JAR=$(jar_path)
  if [[ -z "$JAR" ]]; then
    echo "✗  Build did not produce a JAR. Run ./build to see the error." >&2
    exit 1
  fi
fi

exec java -jar "$JAR" "$@"
