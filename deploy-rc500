#!/bin/zsh
#
# deploy-rc500 — Copy backing.wav and click.wav tracks to a Roland RC-500.
#
# USAGE
#   ./deploy-rc500 [GIG_SLUG] [--dry-run]
#
# CONFIGURATION  (environment variables override .chordprotoolsrc)
#   BACKING_SOURCE_ROOT  — root of the local backing-track library
#   RC500_TARGET_ROOT    — mount point / root of the RC-500 device
#
# SOURCE LAYOUT  (resolved from Song ID in gigs.csv)
#   <BACKING_SOURCE_ROOT>/<CLUSTER>/<LETTER>/<Artist>/<SongTitle>/backing.wav
#   <BACKING_SOURCE_ROOT>/<CLUSTER>/<LETTER>/<Artist>/<SongTitle>/click.wav
#
# TARGET LAYOUT  (standard RC-500 WAVE folder structure)
#   <RC500_TARGET_ROOT>/ROLAND/WAVE/<NNN>_1/backing.wav   ← NNN = zero-padded RC slot
#   <RC500_TARGET_ROOT>/ROLAND/WAVE/<NNN>_2/click.wav
#
# NOTES
#   - backing.wav is REQUIRED.  Missing → WARNING + skip that song.
#   - click.wav is OPTIONAL.   Missing → INFO only; backing still copied.
#   - Key-variant suffixes (-c, -am, -g#m, etc.) are stripped from the
#     song title when resolving the source path (base title is used).

setopt nounset

# ── Paths ─────────────────────────────────────────────────────────────────────
SCRIPT_DIR="${0:a:h}"
GIGS_CSV="${SCRIPT_DIR}/gigs.csv"
CONFIG_FILE="${SCRIPT_DIR}/.chordprotoolsrc"

# ── Logging helpers ───────────────────────────────────────────────────────────
info()    { print -P "%F{cyan}[INFO ]%f  $*" }
warn()    { print -P "%F{yellow}[WARN ]%f  $*" >&2 }
fatal()   { print -P "%F{red}[FATAL]%f  $*" >&2; exit 1 }
banner()  { print -P "%F{green}%B$*%b%f" }
missing() {
    print -P "\n%F{red}%B╔══════════════════════════════════════════════════╗%b%f" >&2
    print -P "%F{red}%B║  ⚠  WARNING: backing.wav NOT FOUND — SKIPPING  ║%b%f" >&2
    print -P "%F{red}%B╟──────────────────────────────────────────────────╢%b%f" >&2
    print -P "%F{red}%B║  Song : $1%b%f" >&2
    print -P "%F{red}%B║  Path : $2%b%f" >&2
    print -P "%F{red}%B╚══════════════════════════════════════════════════╝%b%f\n" >&2
}

# ── Load .chordprotoolsrc (if present) ───────────────────────────────────────
cfg_backing_source_root=""
cfg_rc500_target_root=""

if [[ -f "$CONFIG_FILE" ]]; then
    while IFS= read -r line; do
        # Skip blank lines and comments
        [[ -z "${line//[[:space:]]/}" || "${line}" == \#* ]] && continue
        cfg_key="${line%%=*}"
        cfg_val="${line#*=}"
        cfg_key="${cfg_key//[[:space:]]/}"   # strip all spaces from key
        cfg_val="${cfg_val##[[:space:]]}"     # strip leading space from value
        cfg_val="${cfg_val%%[[:space:]]}"     # strip trailing space from value
        case "$cfg_key" in
            backing_source_root) cfg_backing_source_root="$cfg_val" ;;
            rc500_target_root)   cfg_rc500_target_root="$cfg_val"   ;;
        esac
    done < "$CONFIG_FILE"
fi

# ── Resolve final config (env vars win over config file) ─────────────────────
BACKING_SOURCE_ROOT="${BACKING_SOURCE_ROOT:-$cfg_backing_source_root}"
RC500_TARGET_ROOT="${RC500_TARGET_ROOT:-$cfg_rc500_target_root}"

[[ -z "$BACKING_SOURCE_ROOT" ]] && fatal \
    "BACKING_SOURCE_ROOT is not set.\nExport it or set backing_source_root in .chordprotoolsrc"
[[ -z "$RC500_TARGET_ROOT" ]] && fatal \
    "RC500_TARGET_ROOT is not set.\nExport it or set rc500_target_root in .chordprotoolsrc"

# ── Parse arguments ───────────────────────────────────────────────────────────
dry_run=false
gig_arg=""

for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) dry_run=true ;;
        --help|-h)
            print "Usage: deploy-rc500 [GIG_SLUG] [--dry-run]"
            print ""
            print "  GIG_SLUG    Gig to deploy (defaults to latest gig in gigs.csv)"
            print "  --dry-run   Preview copy operations without writing any files"
            print ""
            print "Config (env vars override .chordprotoolsrc):"
            print "  BACKING_SOURCE_ROOT   Root of local backing-track library"
            print "  RC500_TARGET_ROOT     RC-500 mount point / root directory"
            exit 0
            ;;
        --*)
            fatal "Unknown option: $arg  (try --help)"
            ;;
        *)
            [[ -n "$gig_arg" ]] && fatal "Too many arguments. Usage: deploy-rc500 [GIG_SLUG] [--dry-run]"
            gig_arg="$arg"
            ;;
    esac
done

# ── Resolve gig (default: lexicographically latest in gigs.csv) ───────────────
if [[ -z "$gig_arg" ]]; then
    gig_arg=$(tail -n +2 "$GIGS_CSV" \
        | cut -d, -f1 \
        | tr -d '\r' \
        | sort -u \
        | tail -1)
    [[ -z "$gig_arg" ]] && fatal "Could not determine gig from $GIGS_CSV"
    info "No gig specified — defaulting to latest: $gig_arg"
fi

# ── Verify gig exists in gigs.csv ────────────────────────────────────────────
if ! grep -q "^${gig_arg}," "$GIGS_CSV" 2>/dev/null; then
    fatal "Gig not found in gigs.csv: '$gig_arg'"
fi

# ── Validate RC-500 target is reachable (skip check on dry run) ───────────────
if [[ "$dry_run" == false && ! -d "$RC500_TARGET_ROOT" ]]; then
    fatal "RC-500 target root not found: $RC500_TARGET_ROOT\nIs the RC-500 connected and mounted?"
fi

banner "═══════════════════════════════════════════════════════════════"
banner "  RC-500 Deploy"
banner "  Gig    : $gig_arg"
banner "  Source : $BACKING_SOURCE_ROOT"
banner "  Target : $RC500_TARGET_ROOT"
[[ "$dry_run" == true ]] && banner "  *** DRY RUN — no files will be written ***"
banner "═══════════════════════════════════════════════════════════════"

# ── Key-variant suffix pattern (mirrors Java SongId.KEY_ALT_PATTERN) ─────────
# Strips: -c  -am  -g#m  -bb  -e
# Keeps:  -old  -MVP  -orig  -bass  -lyrics  (not a music key letter range)
KEY_ALT_RE='^(.*)-[a-gA-G][#b]?m?$'

# ── Counters ──────────────────────────────────────────────────────────────────
copied=0
skipped=0
warned=0
no_click=0
no_slot=0

# ── Main loop — process each row in gigs.csv ─────────────────────────────────
while IFS=, read -r row_gig row_song_id row_set row_rc_slot; do

    # Skip CSV header
    [[ "$row_gig" == "GIG" ]] && continue

    # Skip other gigs
    [[ "$row_gig" != "$gig_arg" ]] && continue

    # Strip all whitespace from the slot field (handles \r, spaces, empty)
    rc_slot="${row_rc_slot//[[:space:]]/}"

    # Skip songs without an RC slot assigned
    if [[ -z "$rc_slot" ]]; then
        no_slot=$(( no_slot + 1 ))
        continue
    fi

    # ── Parse Song ID: CLUSTER:LETTER:ARTIST:SONG_STEM ───────────────────────
    parts=("${(@s/:/)row_song_id}")
    if (( ${#parts} < 4 )); then
        warn "Unparseable Song ID '$row_song_id' — skipping"
        skipped=$(( skipped + 1 ))
        continue
    fi
    cluster="${parts[1]}"
    letter="${parts[2]}"
    artist="${parts[3]}"
    song_stem="${parts[4]}"

    # Strip key-variant suffix to arrive at the base folder title
    base_title="$song_stem"
    if [[ "$song_stem" =~ $KEY_ALT_RE ]]; then
        base_title="${match[1]}"
    fi

    # ── Build source and target paths ─────────────────────────────────────────
    src_dir="${BACKING_SOURCE_ROOT}/${cluster}/${letter}/${artist}/${base_title}"
    src_backing="${src_dir}/backing.wav"
    src_click="${src_dir}/click.wav"

    nnn=$(printf "%03d" "$rc_slot")
    tgt_backing_dir="${RC500_TARGET_ROOT}/ROLAND/WAVE/${nnn}_1"
    tgt_click_dir="${RC500_TARGET_ROOT}/ROLAND/WAVE/${nnn}_2"

    info "────────────────────────────────────────────────────────────────"
    info "Slot ${nnn} | ${artist} / ${base_title}  (set: ${row_set})"
    info "  src: ${src_dir}"

    # ── backing.wav — REQUIRED ────────────────────────────────────────────────
    if [[ ! -f "$src_backing" ]]; then
        missing "${artist} / ${base_title}" "${src_backing}"
        warned=$(( warned + 1 ))
        skipped=$(( skipped + 1 ))
        continue
    fi

    # ── click.wav — OPTIONAL ──────────────────────────────────────────────────
    has_click=false
    if [[ ! -f "$src_click" ]]; then
        info "  No click.wav — only backing track will be copied"
        no_click=$(( no_click + 1 ))
    else
        has_click=true
    fi

    # ── Copy (or preview on dry run) ──────────────────────────────────────────
    if [[ "$dry_run" == true ]]; then
        info "  [DRY] ${src_backing} → ${tgt_backing_dir}/backing.wav"
        [[ "$has_click" == true ]] && \
            info "  [DRY] ${src_click} → ${tgt_click_dir}/click.wav"
    else
        mkdir -p "$tgt_backing_dir"
        cp "$src_backing" "${tgt_backing_dir}/backing.wav"
        info "  ✔ backing.wav → ${tgt_backing_dir}/"

        if [[ "$has_click" == true ]]; then
            mkdir -p "$tgt_click_dir"
            cp "$src_click" "${tgt_click_dir}/click.wav"
            info "  ✔ click.wav  → ${tgt_click_dir}/"
        fi
    fi

    copied=$(( copied + 1 ))

done < "$GIGS_CSV"

# ── Summary ───────────────────────────────────────────────────────────────────
banner ""
banner "═══════════════════════════════════════════════════════════════"
banner "  Summary: $gig_arg"
[[ "$dry_run" == true ]] && banner "  (DRY RUN — no files were written)"
banner "═══════════════════════════════════════════════════════════════"
info "  Songs copied     : $copied"
info "  Backing only     : $no_click  (no click track found — that's OK)"
info "  Skipped          : $skipped"
info "  No slot assigned : $no_slot  (run assign-backing-track-slots first?)"
if (( warned > 0 )); then
    print -P "%F{red}%B  ⚠  WARNINGS       : ${warned}  ← missing backing.wav files!%b%f"
fi
banner "═══════════════════════════════════════════════════════════════"
banner ""
