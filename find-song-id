#!/bin/zsh
# Search song-catalog.csv by title or artist fragment.
# Prints one row per song (base version) with TITLE, ARTIST, KEY, SONG ID.
# Songs that also exist in alternate keys are annotated with (+N variants).
#
# Usage:  ./find-song-id <fragment>
#         ./find-song-id "piano"
#         ./find-song-id "joel"

if [[ -z "$1" ]]; then
  echo "Usage: ./find-song-id <title-or-artist-fragment>"
  exit 1
fi

python3 - "$1" <<'PYEOF'
import csv, sys, re

KEY_ALT = re.compile(r'-[a-gA-G][#b]?m?$')
fragment = sys.argv[1].lower()

# Build a two-level index:
#   group_key -> {'base': row | None, 'variants': [row, ...]}
groups = {}
with open("song-catalog.csv", newline="", encoding="utf-8") as f:
    for row in csv.DictReader(f):
        sid = row["SONG ID"]
        gk  = KEY_ALT.sub("", sid)          # strip key suffix to get group key
        if gk not in groups:
            groups[gk] = {"base": None, "variants": []}
        if sid == gk:
            groups[gk]["base"] = row
        else:
            groups[gk]["variants"].append(row)

# Filter to groups where the title or artist matches the fragment
matches = [
    (gk, info)
    for gk, info in groups.items()
    if info["base"] is not None
    and (fragment in info["base"]["TITLE"].lower()
         or fragment in info["base"]["ARTIST"].lower())
]

if not matches:
    print(f"\nNo songs found matching '{sys.argv[1]}'\n")
    sys.exit(1)

fmt = "{:<40}  {:<25}  {:<5}  {:<40}  {}"
print()
print(fmt.format("TITLE", "ARTIST", "KEY", "SONG ID (paste into setlist)", "VARIANTS"))
print("-" * 120)
for gk, info in sorted(matches, key=lambda x: x[1]["base"]["TITLE"].lower()):
    base = info["base"]
    variant_count = len(info["variants"])
    variant_note  = f"+{variant_count} key variant{'s' if variant_count != 1 else ''}" if variant_count else ""
    print(fmt.format(
        base["TITLE"][:40],
        base["ARTIST"][:25],
        base.get("KEY", "")[:5],
        gk,
        variant_note,
    ))
print()
PYEOF
