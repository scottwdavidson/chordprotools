#!/bin/zsh
# Search song-catalog.csv by title or artist fragment.
# Prints one row per song (base version) with TITLE, ARTIST, KEY, SONG ID.
# Songs that also exist in alternate keys are annotated with (+N variants).
#
# Usage:  ./find-song-id <fragment>
#         ./find-song-id "piano"
#         ./find-song-id "joel"

if [[ -z "$1" ]]; then
  echo "Usage: ./find-song-id <title-or-artist-fragment>"
  exit 1
fi

python3 - "$1" <<'PYEOF'
import csv, sys, re

KEY_ALT = re.compile(r'-[a-gA-G][#b]?m?$')
fragment = sys.argv[1].lower()

# Build a two-level index:
#   group_key -> {'base': row | None, 'variants': [row, ...]}
groups = {}
with open("song-catalog.csv", newline="", encoding="utf-8") as f:
    for row in csv.DictReader(f):
        sid = row["SONG ID"]
        gk  = KEY_ALT.sub("", sid)          # strip key suffix to get group key
        if gk not in groups:
            groups[gk] = {"base": None, "variants": []}
        if sid == gk:
            groups[gk]["base"] = row
        else:
            groups[gk]["variants"].append(row)

# Filter to groups where the title or artist matches the fragment.
# Orphaned variants (no base version in catalog) are surfaced with a warning
# rather than silently dropped.
matches = []
for gk, info in groups.items():
    representative = info["base"]
    is_orphan = False
    if representative is None:
        if not info["variants"]:
            continue
        representative = info["variants"][0]   # promote first variant for matching
        is_orphan = True
    if (fragment in representative["TITLE"].lower()
            or fragment in representative["ARTIST"].lower()):
        matches.append((gk, info, representative, is_orphan))

if not matches:
    print(f"\nNo songs found matching '{sys.argv[1]}'\n")
    sys.exit(1)

fmt = "{:<40}  {:<25}  {:<5}  {:<40}  {}"
print()
print(fmt.format("TITLE", "ARTIST", "KEY", "SONG ID (paste into setlist)", "VARIANTS"))
print("-" * 120)
for gk, info, representative, is_orphan in sorted(matches, key=lambda x: x[2]["TITLE"].lower()):
    variant_count = len(info["variants"])
    if is_orphan:
        # No base version — show the actual variant SONG ID but flag it
        display_sid  = representative["SONG ID"]
        variant_note = "[!] ID has key suffix — data needs fix before use in setlist"
    else:
        display_sid   = gk
        variant_note  = (f"+{variant_count} key variant{'s' if variant_count != 1 else ''}"
                         if variant_count else "")
    print(fmt.format(
        representative["TITLE"][:40],
        representative["ARTIST"][:25],
        representative.get("KEY", "")[:5],
        display_sid,
        variant_note,
    ))
print()
PYEOF
